# API base URL. When running on a physical device or emulator, use your machine's
# LAN IP (e.g. http://192.168.1.100:3333), not localhost — the device cannot reach localhost.
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3333

# Pusher (for async voice: real-time voice result delivery). Get from dashboard.pusher.com.
# If unset, voice may fall back to sync or use defaults; backend must have matching Pusher app.
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=
